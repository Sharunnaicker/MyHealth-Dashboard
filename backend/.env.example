# Copy this file to `.env` and fill in the values from your Google Cloud OAuth client.
# (APIs & Services -> Credentials -> your OAuth 2.0 Web application client)

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Must EXACTLY match the Authorized redirect URI you registered in Google Cloud.
REDIRECT_URI=http://localhost:8000/auth/callback

# Where the backend sends you back to after a successful OAuth callback.
FRONTEND_URL=http://localhost:3000

# Anthropic API key for the AI health assistant chat (console.anthropic.com).
# Optional — the dashboard works without it; the chat panel stays disabled until set.
ANTHROPIC_API_KEY=sk-ant-...
